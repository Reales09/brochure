---
import { ClientRouter } from "astro:transitions";

export interface Props {
  lang?: "es" | "en";
}

const { lang = "es" } = Astro.props;

const meta = {
  es: {
    title: "Reales Myles Clarence | Full Stack Mobile Developer",
    description:
      "Full Stack Mobile Developer con +8 años de experiencia. Especializado en Flutter, Android e iOS, con dominio de frontend, backend, cloud (Docker/Kubernetes) e Inteligencia Artificial aplicada.",
    rights: "Todos los derechos reservados.",
  },
  en: {
    title: "Reales Myles Clarence | Full Stack Mobile Developer",
    description:
      "Full Stack Mobile Developer with 8+ years of experience. Specialized in Flutter, Android and iOS, with command of frontend, backend, cloud (Docker/Kubernetes) and applied Artificial Intelligence.",
    rights: "All rights reserved.",
  },
}[lang];

const { title, description } = meta;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Reales Myles Clarence" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Theme -->
    <meta name="theme-color" content="#000000" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <!-- Background Effects -->
    <div class="bg-effects" transition:persist>
      <div class="bg-gradient"></div>
      <div class="bg-grid"></div>
      <div class="bg-glow bg-glow-1"></div>
      <div class="bg-glow bg-glow-2"></div>
      <div class="bg-glow bg-glow-3"></div>
    </div>

    <!-- Custom Cursor -->
    <div class="cursor-dot" id="cursor-dot" transition:persist></div>
    <div class="cursor-ring" id="cursor-ring" transition:persist></div>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <p class="footer-text">
          © 2026 <span class="gradient-text">Reales Myles Clarence</span>. {
            meta.rights
          }
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<style>
  /* === Background Effects === */
  .bg-effects {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -1;
    overflow: hidden;
  }

  .bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(
        ellipse 90% 50% at 50% -20%,
        rgba(255, 255, 255, 0.08),
        transparent 70%
      ),
      radial-gradient(
        ellipse 60% 40% at 100% 0%,
        rgba(200, 200, 210, 0.05),
        transparent 70%
      ),
      radial-gradient(
        ellipse 50% 40% at 0% 100%,
        rgba(180, 180, 190, 0.04),
        transparent 70%
      );
  }

  .bg-grid {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 96px 96px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent);
  }

  .bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
  }

  .bg-glow-1 {
    width: 600px;
    height: 600px;
    background: rgba(255, 255, 255, 0.07);
    top: -220px;
    left: -120px;
    animation: float 22s ease-in-out infinite;
  }

  .bg-glow-2 {
    width: 420px;
    height: 420px;
    background: rgba(190, 190, 200, 0.05);
    top: 42%;
    right: -120px;
    animation: float 26s ease-in-out infinite reverse;
  }

  .bg-glow-3 {
    width: 520px;
    height: 520px;
    background: rgba(160, 160, 170, 0.045);
    bottom: -220px;
    left: 30%;
    animation: float 24s ease-in-out infinite 2s;
  }

  /* === Custom Cursor === */
  .cursor-dot {
    position: fixed;
    width: 7px;
    height: 7px;
    background: #f5f5f7;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition:
      transform 0.1s ease,
      opacity 0.3s ease;
  }

  .cursor-ring {
    position: fixed;
    width: 38px;
    height: 38px;
    border: 1.5px solid rgba(245, 245, 247, 0.5);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    transform: translate(-50%, -50%);
    transition:
      transform 0.15s ease,
      width 0.3s ease,
      height 0.3s ease,
      opacity 0.3s ease,
      border-color 0.3s ease;
    opacity: 0.6;
  }

  .cursor-ring.hover {
    width: 58px;
    height: 58px;
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.04);
  }

  @media (max-width: 768px) {
    .cursor-dot,
    .cursor-ring {
      display: none;
    }
  }

  /* === Footer === */
  .footer {
    padding: var(--space-8) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    text-align: center;
  }

  .footer-text {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .heart {
    display: inline-block;
    animation: pulse 1s ease-in-out infinite;
  }

  .footer a {
    font-weight: 600;
  }
</style>

<script>
  // El cursor y el seguimiento se inicializan UNA sola vez (elementos persistidos
  // con transition:persist), guardando contra doble inicialización entre navegaciones.
  function initCursor() {
    if ((window as any).__cursorInit) return;
    const cursorDot = document.getElementById("cursor-dot");
    const cursorRing = document.getElementById("cursor-ring");
    if (!cursorDot || !cursorRing) return;
    (window as any).__cursorInit = true;

    let mouseX = 0,
      mouseY = 0;
    let ringX = 0,
      ringY = 0;

    document.addEventListener("mousemove", (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursorDot.style.left = `${mouseX}px`;
      cursorDot.style.top = `${mouseY}px`;
    });

    function animateRing() {
      if (!cursorRing) return;
      ringX += (mouseX - ringX) * 0.15;
      ringY += (mouseY - ringY) * 0.15;
      cursorRing.style.left = `${ringX}px`;
      cursorRing.style.top = `${ringY}px`;
      requestAnimationFrame(animateRing);
    }
    animateRing();
  }

  // Los listeners de hover se re-asocian en cada navegación (el contenido cambia)
  function attachHover() {
    const cursorRing = document.getElementById("cursor-ring");
    if (!cursorRing) return;
    document
      .querySelectorAll("a, button, .card, .skill-card, .timeline-item")
      .forEach((el) => {
        el.addEventListener("mouseenter", () =>
          cursorRing.classList.add("hover"),
        );
        el.addEventListener("mouseleave", () =>
          cursorRing.classList.remove("hover"),
        );
      });
  }

  document.addEventListener("astro:page-load", () => {
    initCursor();
    attachHover();
  });
</script>
