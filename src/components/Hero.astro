</section>

<style>
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        padding: var(--space-20) 0;
        overflow: hidden;
    }

    .hero-content {
        text-align: center;
        max-width: 900px;
        margin: 0 auto;
        position: relative;
        z-index: 2;
    }

    /* Badge */
    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        background: var(--glass-bg-strong);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-text);
        margin-bottom: var(--space-6);
    }

    .badge-icon {
        font-size: var(--text-lg);
        display: inline-flex;
    }

    .badge-icon svg {
        width: 16px;
        height: 16px;
    }

    /* Title */
    .hero-title {
        font-size: var(--text-6xl);
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: var(--space-6);
    }

    .hero-greeting {
        display: block;
        font-size: var(--text-xl);
        font-weight: 400;
        color: var(--color-text-muted);
        margin-bottom: var(--space-2);
    }

    .hero-name {
        display: block;
    }

    /* Tagline */
    .hero-tagline {
        font-size: var(--text-xl);
        color: var(--color-text-muted);
        font-family: var(--font-mono);
        letter-spacing: -0.01em;
        margin-bottom: var(--space-6);
        min-height: 1.5em;
    }

    .typewriter-cursor {
        display: inline-block;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        50% {
            opacity: 0;
        }
    }

    /* Description */
    .hero-description {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
        max-width: 700px;
        margin: 0 auto var(--space-8);
        line-height: 1.8;
    }

    .hero-description strong {
        color: var(--color-text);
    }

    .highlight {
        font-weight: 600;
        padding: 0 var(--space-1);
        border-radius: var(--radius-sm);
    }

    .highlight.flutter,
    .highlight.android,
    .highlight.ios {
        color: #fff;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

    /* Tech Stack */
    .tech-stack {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-3);
        margin-bottom: var(--space-10);
    }

    .tech-pill {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        font-weight: 500;
        transition: all var(--transition-base);
        cursor: default;
        background: var(--glass-bg-strong);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        color: var(--color-text);
        border: 1px solid var(--glass-border-strong);
    }

    .tech-icon {
        width: 18px;
        height: 18px;
        color: var(--color-text-muted);
    }

    .tech-pill:hover {
        transform: translateY(-2px) scale(1.04);
        background: rgba(255, 255, 255, 0.12);
        border-color: rgba(255, 255, 255, 0.28);
        box-shadow: var(--shadow-md);
    }

    .tech-pill:hover .tech-icon {
        color: #fff;
    }

    /* CTA */
    .hero-cta {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-4);
    }

    /* Floating Cards */
    .hero-floating {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .floating-card {
        position: absolute;
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-4);
        background: rgba(20, 20, 22, 0.6);
        backdrop-filter: blur(20px) saturate(150%);
        -webkit-backdrop-filter: blur(20px) saturate(150%);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-lg);
        font-size: var(--text-sm);
        font-weight: 500;
        box-shadow: var(--shadow-lg);
    }

    .floating-icon {
        position: relative;
        width: 32px;
        height: 32px;
        display: grid;
        place-items: center;
        font-size: var(--text-base);
        border-radius: 9px;
        background: linear-gradient(
            160deg,
            rgba(255, 255, 255, 0.18) 0%,
            rgba(255, 255, 255, 0.05) 55%,
            rgba(255, 255, 255, 0.02) 100%
        );
        border: 1px solid rgba(255, 255, 255, 0.16);
        box-shadow:
            inset 0 1px 1px rgba(255, 255, 255, 0.4),
            0 4px 10px -4px rgba(0, 0, 0, 0.5);
    }

    .floating-icon::before {
        content: "";
        position: absolute;
        inset: 1px 1px auto 1px;
        height: 46%;
        border-radius: 8px 8px 50% 50%;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.3) 0%,
            transparent 100%
        );
        pointer-events: none;
    }

    .floating-icon svg {
        width: 18px;
        height: 18px;
        color: var(--color-text);
    }

    .floating-card.card-1 {
        top: 20%;
        left: 5%;
        animation: float 8s ease-in-out infinite;
    }

    .floating-card.card-2 {
        top: 40%;
        right: 5%;
        animation: float 10s ease-in-out infinite 1s;
    }

    .floating-card.card-3 {
        bottom: 25%;
        left: 10%;
        animation: float 9s ease-in-out infinite 2s;
    }

    /* Scroll Indicator */
    .scroll-indicator {
        position: absolute;
        bottom: var(--space-8);
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-2);
        color: var(--color-text-subtle);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .scroll-mouse {
        width: 24px;
        height: 40px;
        border: 2px solid var(--color-text-subtle);
        border-radius: var(--radius-full);
        display: flex;
        justify-content: center;
        padding-top: 8px;
    }

    .scroll-wheel {
        width: 4px;
        height: 8px;
        background: var(--color-primary);
        border-radius: var(--radius-full);
        animation: scrollDown 2s ease-in-out infinite;
    }

    @keyframes scrollDown {
        0%,
        100% {
            transform: translateY(0);
            opacity: 1;
        }
        50% {
            transform: translateY(10px);
            opacity: 0.3;
        }
    }

    /* Animation for items */
    .animate-item {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s ease forwards;
    }

    .animate-item:nth-child(1) {
        animation-delay: 0.1s;
    }
    .animate-item:nth-child(2) {
        animation-delay: 0.2s;
    }
    .animate-item:nth-child(3) {
        animation-delay: 0.3s;
    }
    .animate-item:nth-child(4) {
        animation-delay: 0.4s;
    }
    .animate-item:nth-child(5) {
        animation-delay: 0.5s;
    }
    .animate-item:nth-child(6) {
        animation-delay: 0.6s;
    }
    .animate-item:nth-child(7) {
        animation-delay: 0.7s;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .floating-card {
            display: none;
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: var(--space-16) 0;
        }

        .hero-title {
            font-size: var(--text-4xl);
        }

        .hero-greeting {
            font-size: var(--text-base);
        }

        .hero-tagline {
            font-size: var(--text-base);
        }

        .hero-description {
            font-size: var(--text-base);
        }

        .tech-stack {
            gap: var(--space-2);
        }

        .tech-pill {
            font-size: var(--text-xs);
            padding: var(--space-1) var(--space-3);
        }

        .hero-cta {
            flex-direction: column;
            align-items: center;
        }

        .btn {
            width: 100%;
            max-width: 280px;
            justify-content: center;
        }

        .scroll-indicator {
            display: none;
        }
    }
</style>

<script define:vars={{ phrasesEs: t.es.phrases, phrasesEn: t.en.phrases }}>
    // Typewriter effect — reactivo al cambio de idioma.
    // Un contador de generación detiene el timer anterior al cambiar.
    function startTypewriter() {
        const typewriterElement = document.getElementById("typewriter");
        if (!typewriterElement) return;

        const lang = document.documentElement.dataset.lang || "es";
        const phrases = lang === "en" ? phrasesEn : phrasesEs;

        const gen = (window.__twGen || 0) + 1;
        window.__twGen = gen;

        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let typeSpeed = 100;

        function typewrite() {
            if (window.__twGen !== gen || !typewriterElement) return;

            const currentPhrase = phrases[phraseIndex];

            if (isDeleting) {
                typewriterElement.textContent = currentPhrase.substring(
                    0,
                    charIndex - 1,
                );
                charIndex--;
                typeSpeed = 50;
            } else {
                typewriterElement.textContent = currentPhrase.substring(
                    0,
                    charIndex + 1,
                );
                charIndex++;
                typeSpeed = 100;
            }

            if (!isDeleting && charIndex === currentPhrase.length) {
                typeSpeed = 2000;
                isDeleting = true;
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                typeSpeed = 500;
            }

            setTimeout(typewrite, typeSpeed);
        }

        typewrite();
    }

    startTypewriter();
    // Reinicia el typewriter con las frases del nuevo idioma
    document.addEventListener("langchange", startTypewriter);
</script>
