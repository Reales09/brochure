---
// Tech Marquee — carrusel infinito de tecnologías (logo cloud)
import * as si from "simple-icons";

const openai = {
    title: "ChatGPT",
    hex: "10A37F",
    path: "M22.2819 9.8211a5.9847 5.9847 0 0 0-.5157-4.9108 6.0462 6.0462 0 0 0-6.5098-2.9A6.0651 6.0651 0 0 0 4.9807 4.1818a5.9847 5.9847 0 0 0-3.9977 2.9 6.0462 6.0462 0 0 0 .7427 7.0966 5.98 5.98 0 0 0 .511 4.9107 6.051 6.051 0 0 0 6.5146 2.9001A5.9847 5.9847 0 0 0 13.2599 24a6.0557 6.0557 0 0 0 5.7718-4.2058 5.9894 5.9894 0 0 0 3.9977-2.9001 6.0557 6.0557 0 0 0-.7475-7.0729zm-9.022 12.6081a4.4755 4.4755 0 0 1-2.8764-1.0408l.1419-.0804 4.7783-2.7582a.7948.7948 0 0 0 .3927-.6813v-6.7369l2.02 1.1686a.071.071 0 0 1 .038.052v5.5826a4.504 4.504 0 0 1-4.4945 4.4944zm-9.6607-4.1254a4.4708 4.4708 0 0 1-.5346-3.0137l.142.0852 4.783 2.7582a.7712.7712 0 0 0 .7806 0l5.8428-3.3685v2.3324a.0804.0804 0 0 1-.0332.0615L9.74 19.9502a4.4992 4.4992 0 0 1-6.1408-1.6464zM2.3408 7.8956a4.485 4.485 0 0 1 2.3655-1.9728V11.6a.7664.7664 0 0 0 .3879.6765l5.8144 3.3543-2.0201 1.1685a.0757.0757 0 0 1-.071 0l-4.8303-2.7865A4.504 4.504 0 0 1 2.3408 7.872zm16.5963 3.8558L13.1038 8.364 15.1192 7.2a.0757.0757 0 0 1 .071 0l4.8303 2.7913a4.4944 4.4944 0 0 1-.6765 8.1042v-5.6772a.79.79 0 0 0-.407-.667zm2.0107-3.0231l-.142-.0852-4.7735-2.7818a.7759.7759 0 0 0-.7854 0L9.409 9.2297V6.8974a.0662.0662 0 0 1 .0284-.0615l4.8303-2.7866a4.4992 4.4992 0 0 1 6.6802 4.66zM8.3065 12.863l-2.02-1.1638a.0804.0804 0 0 1-.038-.0567V6.0742a4.4992 4.4992 0 0 1 7.3757-3.4537l-.142.0805L8.704 5.459a.7948.7948 0 0 0-.3927.6813zm1.0976-2.3654l2.602-1.4998 2.6069 1.4998v2.9994l-2.5974 1.4997-2.6067-1.4997Z",
};

const ICONS: Record<string, any> = {
    claude: si.siClaude,
    anthropic: si.siAnthropic,
    chatgpt: openai,
    gemini: si.siGooglegemini,
    copilot: si.siGithubcopilot,
    cursor: si.siCursor,
    flutter: si.siFlutter,
    dart: si.siDart,
    android: si.siAndroid,
    kotlin: si.siKotlin,
    java: si.siOpenjdk,
    swift: si.siSwift,
    react: si.siReact,
    javascript: si.siJavascript,
    angular: si.siAngular,
    go: si.siGo,
    html5: si.siHtml5,
    firebase: si.siFirebase,
    postgresql: si.siPostgresql,
    mysql: si.siMysql,
    mariadb: si.siMariadb,
    docker: si.siDocker,
    kubernetes: si.siKubernetes,
    git: si.siGit,
    github: si.siGithub,
    gitlab: si.siGitlab,
    jira: si.siJira,
};

const order = [
    "claude",
    "chatgpt",
    "gemini",
    "anthropic",
    "copilot",
    "cursor",
    "flutter",
    "dart",
    "android",
    "kotlin",
    "java",
    "swift",
    "react",
    "javascript",
    "angular",
    "go",
    "html5",
    "firebase",
    "postgresql",
    "mysql",
    "mariadb",
    "docker",
    "kubernetes",
    "git",
    "github",
    "gitlab",
    "jira",
];

const items = order
    .filter((s) => ICONS[s])
    .map((s) => ({
        slug: s,
        name: ICONS[s].title,
        path: ICONS[s].path,
        color: "#" + ICONS[s].hex,
    }));

// Dos filas desplazándose en sentidos opuestos
const mid = Math.ceil(items.length / 2);
const rowA = items.slice(0, mid);
const rowB = items.slice(mid);

import T from "./T.astro";
const t = {
    es: { title: "Tecnologías que", accent: "manejo", cta: "Ver todo mi stack" },
    en: { title: "Technologies I", accent: "work with", cta: "See my full stack" },
};
---

<section class="tech-marquee section" id="tech">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">
                <T es={t.es.title} en={t.en.title} />
                <span class="gradient-text"
                    ><T es={t.es.accent} en={t.en.accent} /></span
                >
            </h2>
        </div>
    </div>

    <div class="marquee">
        <div class="marquee-row">
            <div class="marquee-track">
                {
                    [...rowA, ...rowA].map((it) => (
                        <span
                            class="brand-badge"
                            title={it.name}
                            aria-label={it.name}
                        >
                            <svg viewBox="0 0 24 24" fill={it.color}>
                                <path d={it.path} />
                            </svg>
                        </span>
                    ))
                }
            </div>
        </div>

        <div class="marquee-row reverse">
            <div class="marquee-track">
                {
                    [...rowB, ...rowB].map((it) => (
                        <span
                            class="brand-badge"
                            title={it.name}
                            aria-label={it.name}
                        >
                            <svg viewBox="0 0 24 24" fill={it.color}>
                                <path d={it.path} />
                            </svg>
                        </span>
                    ))
                }
            </div>
        </div>
    </div>

    <div class="container">
        <div class="marquee-cta">
            <a href="#skills" class="btn btn-primary">
                <T es={t.es.cta} en={t.en.cta} />
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    .tech-marquee {
        position: relative;
        overflow: hidden;
    }

    .section-header {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .section-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        margin-bottom: var(--space-4);
    }

    .section-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
    }

    /* Pista de scroll con desvanecido en los bordes (overlays estáticos,
       más baratos que mask-image sobre contenido en movimiento) */
    .marquee {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .marquee::before,
    .marquee::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 10%;
        max-width: 120px;
        z-index: 2;
        pointer-events: none;
    }

    .marquee::before {
        left: 0;
        background: linear-gradient(90deg, #000, transparent);
    }

    .marquee::after {
        right: 0;
        background: linear-gradient(270deg, #000, transparent);
    }

    .marquee-row {
        display: flex;
        overflow: hidden;
    }

    .marquee-track {
        display: flex;
        gap: var(--space-6);
        width: max-content;
        padding: var(--space-3) 0;
        animation: marquee-scroll 48s linear infinite;
        will-change: transform;
        backface-visibility: hidden;
    }

    .marquee-row.reverse .marquee-track {
        animation-direction: reverse;
        animation-duration: 56s;
    }

    .marquee:hover .marquee-track {
        animation-play-state: paused;
    }

    @keyframes marquee-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    /* Badge circular blanco con el logo en su color real */
    .brand-badge {
        flex-shrink: 0;
        width: 88px;
        height: 88px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #ffffff;
        box-shadow: 0 8px 20px -10px rgba(0, 0, 0, 0.6);
        transition: transform var(--transition-base);
    }

    .brand-badge:hover {
        transform: translateY(-6px) scale(1.08);
    }

    .brand-badge svg {
        width: 42px;
        height: 42px;
    }

    .marquee-cta {
        display: flex;
        justify-content: center;
        margin-top: var(--space-12);
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: var(--text-3xl);
        }

        .brand-badge {
            width: 70px;
            height: 70px;
        }

        .brand-badge svg {
            width: 34px;
            height: 34px;
        }

        .marquee {
            gap: var(--space-4);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
        }
    }
</style>
