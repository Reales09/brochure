---
// Tech Marquee — carrusel infinito de tecnologías (logo cloud)
import * as si from "simple-icons";

const ICONS: Record<string, any> = {
    flutter: si.siFlutter,
    dart: si.siDart,
    android: si.siAndroid,
    kotlin: si.siKotlin,
    java: si.siOpenjdk,
    swift: si.siSwift,
    react: si.siReact,
    javascript: si.siJavascript,
    angular: si.siAngular,
    go: si.siGo,
    html5: si.siHtml5,
    firebase: si.siFirebase,
    postgresql: si.siPostgresql,
    mysql: si.siMysql,
    mariadb: si.siMariadb,
    docker: si.siDocker,
    kubernetes: si.siKubernetes,
    git: si.siGit,
    github: si.siGithub,
    gitlab: si.siGitlab,
    jira: si.siJira,
};

const order = [
    "flutter",
    "dart",
    "android",
    "kotlin",
    "java",
    "swift",
    "react",
    "javascript",
    "angular",
    "go",
    "html5",
    "firebase",
    "postgresql",
    "mysql",
    "mariadb",
    "docker",
    "kubernetes",
    "git",
    "github",
    "gitlab",
    "jira",
];

const items = order
    .filter((s) => ICONS[s])
    .map((s) => ({
        slug: s,
        name: ICONS[s].title,
        path: ICONS[s].path,
        color: "#" + ICONS[s].hex,
    }));

// Dos filas desplazándose en sentidos opuestos
const mid = Math.ceil(items.length / 2);
const rowA = items.slice(0, mid);
const rowB = items.slice(mid);
---

<section class="tech-marquee section" id="tech">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">
                Tecnologías que <span class="gradient-text">manejo</span>
            </h2>
        </div>
    </div>

    <div class="marquee">
        <div class="marquee-row">
            <div class="marquee-track">
                {
                    [...rowA, ...rowA].map((it) => (
                        <span
                            class="brand-badge"
                            title={it.name}
                            aria-label={it.name}
                        >
                            <svg viewBox="0 0 24 24" fill={it.color}>
                                <path d={it.path} />
                            </svg>
                        </span>
                    ))
                }
            </div>
        </div>

        <div class="marquee-row reverse">
            <div class="marquee-track">
                {
                    [...rowB, ...rowB].map((it) => (
                        <span
                            class="brand-badge"
                            title={it.name}
                            aria-label={it.name}
                        >
                            <svg viewBox="0 0 24 24" fill={it.color}>
                                <path d={it.path} />
                            </svg>
                        </span>
                    ))
                }
            </div>
        </div>
    </div>

    <div class="container">
        <div class="marquee-cta">
            <a href="#skills" class="btn btn-primary">
                Ver todo mi stack
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
    </div>
</section>

<style>
    .tech-marquee {
        position: relative;
        overflow: hidden;
    }

    .section-header {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .section-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        margin-bottom: var(--space-4);
    }

    .section-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
    }

    /* Pista de scroll con desvanecido en los bordes */
    .marquee {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
        -webkit-mask-image: linear-gradient(
            90deg,
            transparent 0%,
            #000 8%,
            #000 92%,
            transparent 100%
        );
        mask-image: linear-gradient(
            90deg,
            transparent 0%,
            #000 8%,
            #000 92%,
            transparent 100%
        );
    }

    .marquee-row {
        display: flex;
        overflow: hidden;
    }

    .marquee-track {
        display: flex;
        gap: var(--space-6);
        width: max-content;
        padding: var(--space-3) 0;
        animation: marquee-scroll 48s linear infinite;
    }

    .marquee-row.reverse .marquee-track {
        animation-direction: reverse;
        animation-duration: 56s;
    }

    .marquee:hover .marquee-track {
        animation-play-state: paused;
    }

    @keyframes marquee-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    /* Badge circular blanco con el logo en su color real */
    .brand-badge {
        flex-shrink: 0;
        width: 88px;
        height: 88px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: #ffffff;
        box-shadow:
            0 10px 28px -10px rgba(0, 0, 0, 0.65),
            inset 0 0 0 1px rgba(0, 0, 0, 0.04);
        transition:
            transform var(--transition-base),
            box-shadow var(--transition-base);
    }

    .brand-badge:hover {
        transform: translateY(-6px) scale(1.08);
        box-shadow:
            0 18px 36px -12px rgba(0, 0, 0, 0.8),
            inset 0 0 0 1px rgba(0, 0, 0, 0.04);
    }

    .brand-badge svg {
        width: 42px;
        height: 42px;
    }

    .marquee-cta {
        display: flex;
        justify-content: center;
        margin-top: var(--space-12);
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: var(--text-3xl);
        }

        .brand-badge {
            width: 70px;
            height: 70px;
        }

        .brand-badge svg {
            width: 34px;
            height: 34px;
        }

        .marquee {
            gap: var(--space-4);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
        }
    }
</style>
