---
// Experience Timeline Component
const experiences = [
    {
        company: "Middlesoft",
        role: "Desarrollador Mobile",
        period: "Nov 2024 – Actualidad",
        location: "Montevideo, Uruguay",
        type: "current",
        description:
            "Desarrollo y mantenimiento de aplicaciones móviles utilizando Flutter y Android nativo.",
        highlights: [
            "Participación activa en decisiones de arquitectura y definición de patrones",
            "Colaboración con producto, UX y QA para entregas de calidad",
            "Mentoría de otros desarrolladores mediante code reviews",
        ],
        technologies: ["Flutter", "Android", "Clean Architecture"],
    },
    {
        company: "Finanzauto",
        role: "Desarrollador Mobile",
        period: "Oct 2023 – Nov 2024",
        location: "Colombia",
        type: "past",
        description:
            "Desarrollo de funcionalidades para aplicaciones móviles orientadas al sector financiero.",
        highlights: [
            "Integración de servicios REST y manejo de autenticación segura",
            "Optimización de tiempo de respuesta y experiencia de usuario",
            "Participación en planificación de sprints y estimación de tareas",
        ],
        technologies: ["React Native", "REST API", "Firebase"],
    },
    {
        company: "AZ Smart Technology",
        role: "Desarrollador Mobile",
        period: "Abr 2022 – Sep 2023",
        location: "Colombia",
        type: "past",
        description:
            "Desarrollo de aplicaciones Android y Flutter para soluciones de rastreo, logística y gestión.",
        highlights: [
            "Apps publicadas: VigiAZ, CeSeM, GpsPort, TrackMe, CargaZ, RutaZ, BYAZ",
            "Implementación de nuevas funcionalidades y mantenimiento correctivo",
            "Coordinación de entregas con clientes internos y externos",
        ],
        technologies: ["Android", "Flutter", "Google Play", "App Store"],
    },
    {
        company: "Teleperformance",
        role: "Desarrollador / Especialista en Soporte Técnico Microsoft",
        period: "Dic 2016 – Mar 2022",
        location: "Colombia",
        type: "past",
        description:
            "Atención y soporte técnico a usuarios Microsoft, resolviendo incidencias con altos niveles de satisfacción.",
        highlights: [
            "Referente técnico en equipos mobile con buenas prácticas",
            "Mentoría a desarrolladores junior y de nivel medio",
            "Participación en iniciativas de mejora de procesos",
        ],
        technologies: ["Microsoft", "Liderazgo", "Soporte Técnico"],
    },
];
---

<section class="experience section" id="experience">
    <div class="container">
        <!-- Section Header -->
        <div class="section-header">
            <span class="section-badge">
                <svg
                    width="15"
                    height="15"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                >
                    <path
                        d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"
                    ></path>
                </svg>
                <span>Trayectoria</span>
            </span>
            <h2 class="section-title">
                Experiencia <span class="gradient-text">Profesional</span>
            </h2>
            <p class="section-subtitle">
                Construyendo soluciones móviles de alto impacto desde 2016
            </p>
        </div>

        <!-- Timeline -->
        <div class="timeline">
            <div class="timeline-line"></div>

            {
                experiences.map((exp, index) => (
                    <div class={`timeline-item ${exp.type}`} data-index={index}>
                        <div class="timeline-dot">
                            <div class="dot-inner" />
                        </div>

                        <div class="timeline-card glass">
                            <div class="card-header">
                                <div class="company-info">
                                    <h3 class="company-name">{exp.company}</h3>
                                    <p class="role">{exp.role}</p>
                                </div>
                                <div class="period-badge">
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <rect
                                            x="3"
                                            y="4"
                                            width="18"
                                            height="18"
                                            rx="2"
                                            ry="2"
                                        />
                                        <line x1="16" y1="2" x2="16" y2="6" />
                                        <line x1="8" y1="2" x2="8" y2="6" />
                                        <line x1="3" y1="10" x2="21" y2="10" />
                                    </svg>
                                    <span>{exp.period}</span>
                                </div>
                            </div>

                            <div class="location">
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                    <circle cx="12" cy="10" r="3" />
                                </svg>
                                <span>{exp.location}</span>
                            </div>

                            <p class="description">{exp.description}</p>

                            <div class="highlights">
                                {exp.highlights.map((highlight) => (
                                    <div class="highlight-item">
                                        <svg
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <polyline points="20 6 9 17 4 12" />
                                        </svg>
                                        <span>{highlight}</span>
                                    </div>
                                ))}
                            </div>

                            <div class="technologies">
                                {exp.technologies.map((tech) => (
                                    <span class="tech-tag">{tech}</span>
                                ))}
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .experience {
        position: relative;
    }

    /* Section Header */
    .section-header {
        text-align: center;
        margin-bottom: var(--space-16);
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        background: var(--glass-bg-strong);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin-bottom: var(--space-4);
    }

    .section-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        margin-bottom: var(--space-4);
    }

    .section-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
    }

    /* Timeline */
    .timeline {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
    }

    .timeline-line {
        position: absolute;
        left: 50%;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(
            180deg,
            transparent 0%,
            rgba(255, 255, 255, 0.55) 10%,
            rgba(255, 255, 255, 0.55) 90%,
            transparent 100%
        );
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.25);
        transform: translateX(-50%);
        z-index: 0;
    }

    /* Timeline Item */
    .timeline-item {
        position: relative;
        display: flex;
        margin-bottom: var(--space-12);
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.6s ease;
    }

    .timeline-item.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .timeline-item:nth-child(odd) {
        flex-direction: row;
        padding-right: calc(50% + var(--space-10));
    }

    .timeline-item:nth-child(even) {
        flex-direction: row-reverse;
        padding-left: calc(50% + var(--space-10));
    }

    /* Timeline Dot */
    .timeline-dot {
        position: absolute;
        left: 50%;
        top: var(--space-6);
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: var(--color-bg);
        border: 3px solid var(--color-primary);
        transform: translateX(-50%);
        z-index: 2;
        transition: all var(--transition-base);
    }

    .timeline-item.current .timeline-dot {
        border-color: #ffffff;
        box-shadow: 0 0 22px rgba(255, 255, 255, 0.6);
        animation: pulse 2s infinite;
    }

    .dot-inner {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 8px;
        height: 8px;
        background: var(--color-primary);
        border-radius: 50%;
        transform: translate(-50%, -50%);
    }

    .timeline-item.current .dot-inner {
        background: #ffffff;
    }

    /* Timeline Card */
    .timeline-card {
        width: 100%;
        padding: var(--space-6);
        border-radius: var(--radius-xl);
        transition: all var(--transition-base);
    }

    .timeline-card:hover {
        transform: translateY(-4px) scale(1.02);
        box-shadow: var(--shadow-xl);
    }

    .timeline-item.current .timeline-card {
        border-color: rgba(255, 255, 255, 0.28);
        background: rgba(255, 255, 255, 0.06);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: var(--space-3);
        flex-wrap: wrap;
        gap: var(--space-3);
    }

    .company-name {
        font-size: var(--text-xl);
        font-weight: 700;
        color: var(--color-text);
        margin-bottom: var(--space-1);
    }

    .role {
        font-size: var(--text-sm);
        color: var(--color-primary-light);
        font-weight: 500;
    }

    .period-badge {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-1) var(--space-3);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        white-space: nowrap;
    }

    .location {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        font-size: var(--text-sm);
        color: var(--color-text-subtle);
        margin-bottom: var(--space-4);
    }

    .description {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-bottom: var(--space-4);
    }

    /* Highlights */
    .highlights {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
    }

    .highlight-item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-2);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }

    .highlight-item svg {
        flex-shrink: 0;
        margin-top: 2px;
        color: var(--color-secondary-light);
    }

    /* Technologies */
    .technologies {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .tech-tag {
        padding: var(--space-1) var(--space-3);
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: var(--radius-full);
        font-size: var(--text-xs);
        color: var(--color-text-muted);
        font-weight: 500;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .timeline-line {
            left: var(--space-4);
        }

        .timeline-item:nth-child(odd),
        .timeline-item:nth-child(even) {
            flex-direction: row;
            padding-left: var(--space-12);
            padding-right: 0;
        }

        .timeline-dot {
            left: var(--space-4);
        }

        .card-header {
            flex-direction: column;
        }

        .section-title {
            font-size: var(--text-3xl);
        }
    }
</style>

<script>
    // Intersection Observer for timeline animations
    const timelineObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay =
                        Number((entry.target as HTMLElement).dataset.index) *
                        200;
                    setTimeout(() => {
                        entry.target.classList.add("visible");
                    }, delay);
                    timelineObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.2 },
    );

    document.querySelectorAll(".timeline-item").forEach((item) => {
        timelineObserver.observe(item);
    });
</script>
