---
// Skills Section Component
import * as si from "simple-icons";

// Logos de marca (simple-icons)
const iconMap: Record<string, any> = {
    flutter: si.siFlutter,
    android: si.siAndroid,
    swift: si.siSwift,
    react: si.siReact,
    dart: si.siDart,
    kotlin: si.siKotlin,
    java: si.siOpenjdk, // Java no tiene icono propio (marca Oracle) → OpenJDK
    javascript: si.siJavascript,
    go: si.siGo,
    angular: si.siAngular,
    firebase: si.siFirebase,
    postgresql: si.siPostgresql,
    mysql: si.siMysql,
    mariadb: si.siMariadb,
    docker: si.siDocker,
    kubernetes: si.siKubernetes,
    github: si.siGithub,
    gitlab: si.siGitlab,
    jira: si.siJira,
};

// Iconos propios (estilo Material) para skills sin logo de marca
const customIcons: Record<string, string> = {
    code: '<path d="M9.4 16.6 4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"/>',
    star: '<path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>',
    school: '<path d="M12 3 1 9l11 6 9-4.91V17h2V9zM5 13.18v4L12 21l7-3.82v-4L12 17z"/>',
    chat: '<path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>',
    people: '<path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>',
    heart: '<path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>',
};

type Skill = { name: string; brand?: string; custom?: string };
type Category = { title: string; skills: Skill[] };

const skillCategories: Category[] = [
    {
        title: "Desarrollo Mobile",
        skills: [
            { name: "Flutter", brand: "flutter" },
            { name: "Android · Kotlin", brand: "android" },
            { name: "Android · Java", brand: "android" },
            { name: "iOS · Swift", brand: "swift" },
            { name: "React Native", brand: "react" },
        ],
    },
    {
        title: "Lenguajes",
        skills: [
            { name: "Dart", brand: "dart" },
            { name: "Kotlin", brand: "kotlin" },
            { name: "Java", brand: "java" },
            { name: "Swift", brand: "swift" },
            { name: "JavaScript", brand: "javascript" },
            { name: "Go", brand: "go" },
        ],
    },
    {
        title: "Frontend & Backend",
        skills: [
            { name: "Angular", brand: "angular" },
            { name: "React", brand: "react" },
            { name: "REST APIs", custom: "code" },
            { name: "Firebase", brand: "firebase" },
        ],
    },
    {
        title: "Bases de Datos",
        skills: [
            { name: "PostgreSQL", brand: "postgresql" },
            { name: "MySQL", brand: "mysql" },
            { name: "MariaDB", brand: "mariadb" },
            { name: "Firebase", brand: "firebase" },
        ],
    },
    {
        title: "DevOps & Tools",
        skills: [
            { name: "Docker", brand: "docker" },
            { name: "Kubernetes", brand: "kubernetes" },
            { name: "GitHub", brand: "github" },
            { name: "GitLab", brand: "gitlab" },
            { name: "Jira", brand: "jira" },
        ],
    },
    {
        title: "Habilidades Blandas",
        skills: [
            { name: "Liderazgo", custom: "star" },
            { name: "Mentoría", custom: "school" },
            { name: "Comunicación", custom: "chat" },
            { name: "Trabajo en Equipo", custom: "people" },
            { name: "Inteligencia Emocional", custom: "heart" },
        ],
    },
];

// Luminancia relativa para decidir color del logo (legible sobre fondo negro)
function lum(hex: string) {
    const n = hex.replace("#", "");
    const r = parseInt(n.slice(0, 2), 16);
    const g = parseInt(n.slice(2, 4), 16);
    const b = parseInt(n.slice(4, 6), 16);
    return (0.299 * r + 0.587 * g + 0.114 * b) / 255;
}
function rgba(hex: string, a: number) {
    const n = hex.replace("#", "");
    const r = parseInt(n.slice(0, 2), 16);
    const g = parseInt(n.slice(2, 4), 16);
    const b = parseInt(n.slice(4, 6), 16);
    return `rgba(${r}, ${g}, ${b}, ${a})`;
}
function resolve(skill: Skill) {
    if (skill.brand && iconMap[skill.brand]) {
        const ic = iconMap[skill.brand];
        const hex = "#" + ic.hex;
        const dark = lum(hex) < 0.25;
        return {
            inner: `<path d="${ic.path}"></path>`,
            fill: dark ? "#f5f5f7" : hex,
            glow: dark ? "rgba(255, 255, 255, 0.4)" : rgba(hex, 0.55),
        };
    }
    const c = customIcons[skill.custom ?? "code"] ?? customIcons.code;
    return { inner: c, fill: "#f5f5f7", glow: "rgba(255, 255, 255, 0.4)" };
}
---

<section class="skills section" id="skills">
    <div class="skills-glow" aria-hidden="true"></div>
    <div class="container">
        <!-- Section Header -->
        <div class="section-header">
            <span class="section-badge">
                <span>🛠️</span>
                <span>Stack Tecnológico</span>
            </span>
            <h2 class="section-title">
                Habilidades <span class="gradient-text">Técnicas</span>
            </h2>
            <p class="section-subtitle">
                +8 años perfeccionando el arte del desarrollo mobile
            </p>
        </div>

        <!-- Skill Groups -->
        <div class="skills-groups">
            {
                skillCategories.map((category, catIndex) => (
                    <div
                        class="skill-group"
                        data-group
                        style={`--gi:${catIndex}`}
                    >
                        <div class="group-head">
                            <h3 class="group-title">{category.title}</h3>
                        </div>
                        <div class="app-grid">
                            {category.skills.map((skill, sIdx) => {
                                const r = resolve(skill);
                                return (
                                    <div
                                        class="app-tile"
                                        style={`--i:${sIdx}; --brand:${r.glow}`}
                                    >
                                        <div class="app-icon">
                                            <svg
                                                class="app-logo"
                                                viewBox="0 0 24 24"
                                                fill={r.fill}
                                                role="img"
                                                aria-label={skill.name}
                                                set:html={r.inner}
                                            />
                                        </div>
                                        <span class="app-label">
                                            {skill.name}
                                        </span>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Stats -->
        <div class="stats-row">
            <div class="stat-item glass">
                <span class="stat-number" data-count="8">0</span>
                <span class="stat-label">Años de Experiencia</span>
            </div>
            <div class="stat-item glass">
                <span class="stat-number" data-count="20">0</span>
                <span class="stat-label">Proyectos Entregados</span>
            </div>
            <div class="stat-item glass">
                <span class="stat-number" data-count="5">0</span>
                <span class="stat-label">Empresas</span>
            </div>
            <div class="stat-item glass">
                <span class="stat-number" data-count="10">0</span>
                <span class="stat-label">Apps en Tiendas</span>
            </div>
        </div>
    </div>
</section>

<style>
    .skills {
        position: relative;
        overflow: hidden;
    }

    /* Luz ambiental que sigue el cursor */
    .skills-glow {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0;
        background: radial-gradient(
            440px circle at var(--mx, 50%) var(--my, 30%),
            rgba(255, 255, 255, 0.07),
            transparent 72%
        );
        transition: opacity 450ms var(--ease-ios);
    }

    .skills.glow-active .skills-glow {
        opacity: 1;
    }

    .skills .container {
        position: relative;
        z-index: 1;
    }

    /* Section Header */
    .section-header {
        text-align: center;
        margin-bottom: var(--space-16);
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        background: var(--glass-bg-strong);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border-strong);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin-bottom: var(--space-4);
    }

    .section-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        margin-bottom: var(--space-4);
    }

    .section-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
        max-width: 500px;
        margin: 0 auto;
    }

    /* === Grupos de skills === */
    .skills-groups {
        display: flex;
        flex-direction: column;
        gap: var(--space-12);
        margin-bottom: var(--space-16);
    }

    .group-head {
        display: flex;
        align-items: baseline;
        justify-content: center;
        gap: var(--space-3);
        margin-bottom: var(--space-8);
        padding-bottom: var(--space-3);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .group-title {
        font-size: var(--text-2xl);
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    /* === Cuadrícula de iconos tipo home screen de iOS === */
    .app-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-8) var(--space-6);
    }

    .app-tile {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-3);
        width: 100px;
        opacity: 0;
        transform: translateY(16px) scale(0.94);
        transition:
            opacity var(--transition-base),
            transform var(--transition-base);
        transition-delay: calc(var(--i, 0) * 45ms);
    }

    .skill-group.visible .app-tile {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    /* Halo de color de marca detrás del icono */
    .app-tile::before {
        content: "";
        position: absolute;
        top: 0;
        left: 50%;
        width: 84px;
        height: 84px;
        transform: translateX(-50%);
        border-radius: 50%;
        background: radial-gradient(
            circle,
            var(--brand, rgba(255, 255, 255, 0.3)) 0%,
            transparent 68%
        );
        filter: blur(22px);
        opacity: 0;
        z-index: 0;
        pointer-events: none;
        transition: opacity var(--transition-base);
    }

    .app-tile:hover::before {
        opacity: 0.9;
    }

    /* Squircle de cristal líquido */
    .app-icon {
        position: relative;
        z-index: 1;
        width: 84px;
        height: 84px;
        display: grid;
        place-items: center;
        border-radius: 21px;
        background: linear-gradient(
            160deg,
            rgba(255, 255, 255, 0.16) 0%,
            rgba(255, 255, 255, 0.05) 55%,
            rgba(255, 255, 255, 0.02) 100%
        );
        border: 1px solid rgba(255, 255, 255, 0.16);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        box-shadow:
            inset 0 1.5px 1px rgba(255, 255, 255, 0.42),
            inset 0 -10px 22px -8px rgba(0, 0, 0, 0.35),
            0 18px 32px -14px rgba(0, 0, 0, 0.7);
        transform-style: preserve-3d;
        transition:
            transform 160ms ease,
            box-shadow var(--transition-base);
        will-change: transform;
        cursor: pointer;
        -webkit-box-reflect: below 6px
            linear-gradient(transparent 58%, rgba(0, 0, 0, 0.32));
    }

    /* Reflejo superior tipo cristal */
    .app-icon::before {
        content: "";
        position: absolute;
        inset: 1px 1px auto 1px;
        height: 46%;
        border-radius: 20px 20px 50% 50%;
        background: linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.32) 0%,
            rgba(255, 255, 255, 0) 100%
        );
        pointer-events: none;
    }

    .app-icon:hover {
        box-shadow:
            inset 0 1.5px 1px rgba(255, 255, 255, 0.5),
            inset 0 -10px 22px -8px rgba(0, 0, 0, 0.35),
            0 26px 44px -14px rgba(0, 0, 0, 0.85);
    }

    .app-logo {
        width: 42px;
        height: 42px;
        transform: translateZ(24px);
        filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.45));
    }

    .app-label {
        font-size: var(--text-sm);
        font-weight: 500;
        color: var(--color-text-muted);
        text-align: center;
        letter-spacing: -0.01em;
        transition: color var(--transition-fast);
    }

    .app-tile:hover .app-label {
        color: var(--color-text);
    }

    @media (max-width: 480px) {
        .app-grid {
            gap: var(--space-6) var(--space-4);
        }

        .app-tile {
            width: 84px;
        }

        .app-icon,
        .app-tile::before {
            width: 72px;
            height: 72px;
        }

        .app-icon {
            border-radius: 18px;
        }

        .app-logo {
            width: 36px;
            height: 36px;
        }

        .group-title {
            font-size: var(--text-xl);
        }
    }

    /* Stats Row */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-6);
    }

    @media (max-width: 768px) {
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .stat-item {
        text-align: center;
        padding: var(--space-6);
        border-radius: 24px;
        transition:
            transform var(--transition-base),
            box-shadow var(--transition-base),
            border-color var(--transition-base);
    }

    .stat-item:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-xl);
        border-color: var(--glass-border-strong);
    }

    .stat-number {
        display: block;
        font-size: var(--text-4xl);
        font-weight: 800;
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: var(--space-2);
    }

    .stat-number::after {
        content: "+";
        -webkit-text-fill-color: var(--color-secondary);
    }

    .stat-label {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }
</style>

<script>
    // Revelar grupos al entrar en viewport
    const groupObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    groupObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
    );
    document
        .querySelectorAll(".skill-group")
        .forEach((el) => groupObserver.observe(el));

    // Contadores de estadísticas
    const statObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const numberEl = entry.target.querySelector(".stat-number");
                    if (numberEl) {
                        const target = parseInt(
                            (numberEl as HTMLElement).dataset.count || "0",
                        );
                        animateNumber(numberEl, target);
                    }
                    statObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.4 },
    );
    document
        .querySelectorAll(".stat-item")
        .forEach((el) => statObserver.observe(el));

    function animateNumber(element: Element, target: number) {
        let current = 0;
        const increment = target / 30;
        const stepTime = 1500 / 30;
        const timer = setInterval(() => {
            current += increment;
            if (current >= target) {
                current = target;
                clearInterval(timer);
            }
            (element as HTMLElement).textContent =
                Math.floor(current).toString();
        }, stepTime);
    }

    // Tilt 3D interactivo siguiendo el cursor
    const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;

    if (!reduceMotion) {
        document.querySelectorAll<HTMLElement>(".app-icon").forEach((icon) => {
            icon.addEventListener("pointermove", (e) => {
                const r = icon.getBoundingClientRect();
                const px = (e.clientX - r.left) / r.width - 0.5;
                const py = (e.clientY - r.top) / r.height - 0.5;
                icon.style.transform = `perspective(520px) rotateX(${(-py * 16).toFixed(2)}deg) rotateY(${(px * 16).toFixed(2)}deg) translateY(-6px) scale(1.06)`;
            });
            icon.addEventListener("pointerleave", () => {
                icon.style.transition = "transform 320ms cubic-bezier(0.34,1.56,0.64,1)";
                icon.style.transform = "";
                window.setTimeout(() => {
                    icon.style.transition = "";
                }, 320);
            });
            icon.addEventListener("pointerdown", () => {
                icon.style.transition = "transform 90ms ease";
                icon.style.transform += " scale(0.92)";
            });
            icon.addEventListener("pointerup", () => {
                icon.style.transition = "transform 160ms ease";
            });
        });

        // Luz ambiental que sigue el cursor sobre la sección
        const skillsSection = document.querySelector<HTMLElement>(".skills");
        if (skillsSection) {
            skillsSection.addEventListener("pointermove", (e) => {
                const r = skillsSection.getBoundingClientRect();
                skillsSection.style.setProperty("--mx", `${e.clientX - r.left}px`);
                skillsSection.style.setProperty("--my", `${e.clientY - r.top}px`);
                skillsSection.classList.add("glow-active");
            });
            skillsSection.addEventListener("pointerleave", () => {
                skillsSection.classList.remove("glow-active");
            });
        }
    }
</script>
