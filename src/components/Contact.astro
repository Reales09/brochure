---
// Contact Section Component
const contactLinks = [
    {
        name: "Email",
        icon: "email",
        value: "rclarence123@gmail.com",
        href: "mailto:rclarence123@gmail.com",
        color: "#EA4335",
    },
    {
        name: "LinkedIn",
        icon: "linkedin",
        value: "reales-myles-clarence",
        href: "https://linkedin.com/in/reales-myles-clarence",
        color: "#0A66C2",
    },
    {
        name: "GitHub",
        icon: "github",
        value: "Reales09",
        href: "https://github.com/Reales09",
        color: "#fff",
    },
    {
        name: "Teléfono",
        icon: "phone",
        value: "+57 313 816 8350",
        href: "tel:+573138168350",
        color: "#25D366",
    },
    {
        name: "Google Dev",
        icon: "google",
        value: "g.dev/mylesdev",
        href: "https://g.dev/mylesdev",
        color: "#4285F4",
    },
    {
        name: "Play Store",
        icon: "playstore",
        value: "Mis Apps Publicadas",
        href: "https://play.google.com/store/apps/developer?id=Gps+Port&hl=es_CO",
        color: "#00C853",
    },
];
---

<section class="contact section" id="contact">
    <div class="container">
        <!-- Section Header -->
        <div class="section-header">
            <span class="section-badge">
                <span>📬</span>
                <span>Contáctame</span>
            </span>
            <h2 class="section-title">
                ¿Listo para <span class="gradient-text">Conectar</span>?
            </h2>
            <p class="section-subtitle">
                Estoy abierto a nuevas oportunidades y colaboraciones
                interesantes
            </p>
        </div>

        <!-- Contact Cards -->
        <div class="contact-grid">
            {
                contactLinks.map((contact, index) => (
                    <a
                        href={contact.href}
                        class="contact-card glass"
                        target="_blank"
                        rel="noopener noreferrer"
                        data-index={index}
                        style={`--accent-color: ${contact.color}`}
                    >
                        <div class="contact-icon">
                            {contact.icon === "email" && (
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                    <polyline points="22,6 12,13 2,6" />
                                </svg>
                            )}
                            {contact.icon === "linkedin" && (
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                </svg>
                            )}
                            {contact.icon === "github" && (
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                                </svg>
                            )}
                            {contact.icon === "phone" && (
                                <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                                </svg>
                            )}
                            {contact.icon === "google" && (
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                                </svg>
                            )}
                            {contact.icon === "playstore" && (
                                <svg viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 0 1 0 1.73l-2.808 1.626L15.206 12l2.492-2.491zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z" />
                                </svg>
                            )}
                        </div>
                        <div class="contact-info">
                            <span class="contact-name">{contact.name}</span>
                            <span class="contact-value">{contact.value}</span>
                        </div>
                        <div class="contact-arrow">
                            <svg
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <line x1="5" y1="12" x2="19" y2="12" />
                                <polyline points="12 5 19 12 12 19" />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </div>

        <!-- CTA Banner -->
        <div class="cta-banner glass">
            <div class="cta-content">
                <div class="cta-icon">🚀</div>
                <div class="cta-text">
                    <h3>¿Tienes un proyecto en mente?</h3>
                    <p>
                        Hablemos sobre cómo puedo ayudarte a construir tu
                        próxima app móvil
                    </p>
                </div>
            </div>
            <a href="mailto:rclarence123@gmail.com" class="btn btn-primary">
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                    ></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                Enviar Email
            </a>
        </div>

        <!-- Location -->
        <div class="location-info">
            <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Montevideo, Uruguay</span>
            <span class="separator">•</span>
            <span>Disponible para trabajo remoto 🌎</span>
        </div>
    </div>
</section>

<style>
    .contact {
        position: relative;
    }

    /* Section Header */
    .section-header {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .section-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-4);
        background: rgba(99, 102, 241, 0.1);
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: var(--radius-full);
        font-size: var(--text-sm);
        color: var(--color-primary-light);
        margin-bottom: var(--space-4);
    }

    .section-title {
        font-size: var(--text-4xl);
        font-weight: 800;
        margin-bottom: var(--space-4);
    }

    .section-subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-muted);
    }

    /* Contact Grid */
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: var(--space-4);
        margin-bottom: var(--space-12);
    }

    .contact-card {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        padding: var(--space-5);
        border-radius: var(--radius-xl);
        transition: all var(--transition-base);
        text-decoration: none;
        color: var(--color-text);
        opacity: 0;
        transform: translateY(20px);
    }

    .contact-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .contact-card:hover {
        transform: translateY(-4px) scale(1.02);
        border-color: var(--accent-color);
        box-shadow: 0 10px 40px -10px var(--accent-color);
    }

    .contact-card:hover .contact-icon {
        background: var(--accent-color);
        color: white;
        transform: scale(1.1) rotate(5deg);
    }

    .contact-card:hover .contact-arrow {
        transform: translateX(5px);
        opacity: 1;
    }

    .contact-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        border-radius: var(--radius-lg);
        flex-shrink: 0;
        transition: all var(--transition-base);
    }

    .contact-icon svg {
        width: 24px;
        height: 24px;
    }

    .contact-info {
        flex: 1;
        min-width: 0;
    }

    .contact-name {
        display: block;
        font-size: var(--text-xs);
        color: var(--color-text-subtle);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: var(--space-1);
    }

    .contact-value {
        display: block;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--color-text);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .contact-arrow {
        opacity: 0.3;
        transition: all var(--transition-base);
        color: var(--color-text-muted);
    }

    /* CTA Banner */
    .cta-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
        padding: var(--space-8);
        border-radius: var(--radius-2xl);
        margin-bottom: var(--space-10);
        background: linear-gradient(
            135deg,
            rgba(99, 102, 241, 0.1) 0%,
            rgba(244, 114, 182, 0.1) 100%
        );
        border: 1px solid rgba(99, 102, 241, 0.2);
    }

    .cta-content {
        display: flex;
        align-items: center;
        gap: var(--space-5);
    }

    .cta-icon {
        font-size: var(--text-4xl);
        animation: float 3s ease-in-out infinite;
    }

    .cta-text h3 {
        font-size: var(--text-xl);
        font-weight: 700;
        margin-bottom: var(--space-1);
    }

    .cta-text p {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
    }

    /* Location */
    .location-info {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        flex-wrap: wrap;
    }

    .location-info svg {
        color: var(--color-accent);
    }

    .separator {
        opacity: 0.3;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .section-title {
            font-size: var(--text-3xl);
        }

        .cta-banner {
            flex-direction: column;
            text-align: center;
            padding: var(--space-6);
        }

        .cta-content {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<script>
    // Intersection Observer for animations
    const contactObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const delay =
                        Number((entry.target as HTMLElement).dataset.index) *
                        100;
                    setTimeout(() => {
                        entry.target.classList.add("visible");
                    }, delay);
                    contactObserver.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.2 },
    );

    document.querySelectorAll(".contact-card").forEach((item) => {
        contactObserver.observe(item);
    });
</script>
